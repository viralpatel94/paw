{
  "_comment": "Five roles, least-privilege. Replace ACCOUNT, REGION, and ARNs. The split between base/build/deploy/prod-deploy is the defense-in-depth boundary: the agent's base role literally cannot mutate prod.",

  "agent_base_role": {
    "_use": "Task role for the orchestrator (the process running the agent loop). Can read commits state, read approvals, assume the build and deploy roles. Cannot touch prod ECS directly.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "ReadApprovalsOnly",
        "Effect": "Allow",
        "Action": ["dynamodb:GetItem"],
        "Resource": "arn:aws:dynamodb:REGION:ACCOUNT:table/cd-agent-approvals"
      },
      {
        "Sid": "AssumeWorkerRoles",
        "Effect": "Allow",
        "Action": "sts:AssumeRole",
        "Resource": [
          "arn:aws:iam::ACCOUNT:role/cd-agent-build",
          "arn:aws:iam::ACCOUNT:role/cd-agent-deploy-dev",
          "arn:aws:iam::ACCOUNT:role/cd-agent-deploy-prod"
        ]
      }
    ]
  },

  "build_role": {
    "_use": "Push images to specific ECR repos. Nothing else.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "EcrAuth",
        "Effect": "Allow",
        "Action": "ecr:GetAuthorizationToken",
        "Resource": "*"
      },
      {
        "Sid": "EcrPushScoped",
        "Effect": "Allow",
        "Action": [
          "ecr:BatchCheckLayerAvailability",
          "ecr:InitiateLayerUpload",
          "ecr:UploadLayerPart",
          "ecr:CompleteLayerUpload",
          "ecr:PutImage",
          "ecr:DescribeImages",
          "ecr:BatchGetImage"
        ],
        "Resource": [
          "arn:aws:ecr:REGION:ACCOUNT:repository/paw-web"
        ]
      }
    ]
  },

  "deploy_dev_role": {
    "_use": "Register task defs and update DEV services only.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "RegisterTaskDefs",
        "Effect": "Allow",
        "Action": ["ecs:RegisterTaskDefinition", "ecs:DescribeTaskDefinition", "ecs:ListTaskDefinitions"],
        "Resource": "*"
      },
      {
        "Sid": "UpdateDevServices",
        "Effect": "Allow",
        "Action": ["ecs:UpdateService", "ecs:DescribeServices"],
        "Resource": [
          "arn:aws:ecs:REGION:ACCOUNT:service/paw-dev/paw-web-dev"
        ]
      },
      {
        "Sid": "PassExecRoleScoped",
        "Effect": "Allow",
        "Action": "iam:PassRole",
        "Resource": "arn:aws:iam::ACCOUNT:role/paw-task-execution",
        "Condition": {"StringEquals": {"iam:PassedToService": "ecs-tasks.amazonaws.com"}}
      }
    ]
  },

  "deploy_prod_role": {
    "_use": "Update PROD services. Assumed ONLY inside update_service(env='prod'), which the validator reaches only after a verified human approval. Trust policy should allow only agent_base_role to assume it.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "UpdateProdServices",
        "Effect": "Allow",
        "Action": ["ecs:UpdateService", "ecs:DescribeServices", "ecs:ListTaskDefinitions"],
        "Resource": [
          "arn:aws:ecs:REGION:ACCOUNT:service/paw-prod/paw-web-prod"
        ]
      },
      {
        "Sid": "PassExecRoleScoped",
        "Effect": "Allow",
        "Action": "iam:PassRole",
        "Resource": "arn:aws:iam::ACCOUNT:role/paw-task-execution",
        "Condition": {"StringEquals": {"iam:PassedToService": "ecs-tasks.amazonaws.com"}}
      }
    ]
  },

  "deploy_prod_trust_policy": {
    "_use": "Attach as the TRUST relationship on cd-agent-deploy-prod. Only the orchestrator's base role may assume it.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {"AWS": "arn:aws:iam::ACCOUNT:role/cd-agent-base"},
        "Action": "sts:AssumeRole"
      }
    ]
  },

  "webhook_role": {
    "_use": "Role for the webhook server. The ONLY role allowed to write approval decisions.",
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "WriteApprovals",
        "Effect": "Allow",
        "Action": ["dynamodb:PutItem", "dynamodb:UpdateItem", "dynamodb:GetItem"],
        "Resource": "arn:aws:dynamodb:REGION:ACCOUNT:table/cd-agent-approvals"
      }
    ]
  }
}
